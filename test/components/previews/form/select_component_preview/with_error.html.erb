<%
  options = [["Draft", "draft"], ["Published", "published"], ["Archived", "archived"]]
  post = Post.new
  post.errors.add(:title, "must be selected")
%>
<%= form_with(model: post, url: "#") do |f| %>
  <%= render Form::SelectComponent.new(form: f, attribute: :title,
        options: options_for_select(options)) %>
<% end %>
