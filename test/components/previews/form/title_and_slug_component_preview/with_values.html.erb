<%
  post = Post.new(title: "My Great Post", slug: "/my-great-post")
  post.build_site
  post.site.define_singleton_method(:to_param) { "preview" }
  post.site.define_singleton_method(:public_id) { "preview" }
%>
<%= form_with(model: post, url: "#") do |f| %>
  <%= render Form::TitleAndSlugComponent.new(form: f) %>
<% end %>
