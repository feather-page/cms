<%
  # EditorComponent needs a site context for image upload endpoint URLs.
  # The editor JS shell renders fine; upload/book-lookup are not functional in preview.
  post = Post.new
  post.build_site
  post.site.define_singleton_method(:to_param) { "preview" }
  post.site.define_singleton_method(:public_id) { "preview" }
%>
<%= form_with(model: post, url: "#") do |f| %>
  <%= render Form::EditorComponent.new(form: f, attribute: :content) %>
<% end %>
