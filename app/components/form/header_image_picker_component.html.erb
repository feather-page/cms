<div class="mb-3"
     data-controller="header-image-picker"
     data-header-image-picker-search-url-value="<%= search_url %>"
     data-header-image-picker-create-url-value="<%= create_url %>"
     data-header-image-picker-upload-url-value="<%= upload_url %>">

  <%= form.hidden_field attribute, data: { header_image_picker_target: "coverInput" } %>
  <%= form.hidden_field thumbnail_attribute, data: { header_image_picker_target: "thumbnailInput" } %>
  <%= form.hidden_field emoji_attribute, data: { header_image_picker_target: "emojiInput" } %>

  <!-- Preview Area -->
  <div data-header-image-picker-target="preview" class="header-preview mb-3" style="<%= 'display: none;' unless current_image || current_thumbnail || current_emoji.present? %>">
    <!-- Thumbnail Preview -->
    <div class="thumbnail-preview" data-header-image-picker-target="thumbnailContainer" style="<%= 'display: none;' unless current_thumbnail %>">
      <% if current_thumbnail %>
        <%= image_tag current_thumbnail.file %>
      <% end %>
    </div>

    <!-- Cover Preview -->
    <div class="header-preview-image" data-header-image-picker-target="imageContainer" style="<%= 'display: none;' unless current_image %>">
      <% if current_image %>
        <%= image_tag current_image.file %>
      <% end %>
    </div>

    <!-- Emoji Preview -->
    <% if current_emoji.present? %>
      <button type="button"
              class="header-preview-emoji"
              data-header-image-picker-target="emojiDisplay"
              data-action="header-image-picker#openEmojiPicker"
              title="Click to change icon"><%= current_emoji %></button>
    <% else %>
      <span class="header-preview-emoji" data-header-image-picker-target="emojiDisplay" style="display: none;"></span>
    <% end %>
  </div>

  <!-- Action Buttons -->
  <div class="d-flex gap-2 flex-wrap mb-3 position-relative">
    <!-- Icon Button (standalone) -->
    <button type="button"
            class="btn btn-outline-secondary btn-sm"
            data-action="header-image-picker#openEmojiPicker"
            data-header-image-picker-target="addIconButton">
      рЯША Add icon
    </button>
    <button type="button"
            class="btn btn-outline-danger btn-sm"
            data-action="header-image-picker#removeEmoji"
            data-header-image-picker-target="removeEmojiButton"
            style="<%= 'display: none;' unless current_emoji.present? %>">
      Remove icon
    </button>

    <!-- Thumbnail Button Group -->
    <div class="btn-group" role="group">
      <button type="button"
              class="btn btn-outline-secondary btn-sm"
              data-action="header-image-picker#openUnsplashForThumbnail">
        <%= helpers.icon("image") %> Thumbnail
      </button>

      <button type="button"
              class="btn btn-outline-secondary btn-sm"
              data-action="header-image-picker#openUploadForThumbnail">
        <%= helpers.icon("upload") %> Upload
      </button>
    </div>

    <button type="button"
            class="btn btn-outline-danger btn-sm"
            data-action="header-image-picker#removeThumbnail"
            data-header-image-picker-target="removeThumbnailButton"
            style="<%= 'display: none;' unless current_thumbnail %>">
      Remove thumbnail
    </button>

    <!-- Cover Button Group -->
    <div class="btn-group" role="group">
      <button type="button"
              class="btn btn-outline-secondary btn-sm"
              data-action="header-image-picker#openUnsplashForCover">
        <%= helpers.icon("image") %> Cover
      </button>

      <button type="button"
              class="btn btn-outline-secondary btn-sm"
              data-action="header-image-picker#openUploadForCover">
        <%= helpers.icon("upload") %> Upload
      </button>
    </div>

    <button type="button"
            class="btn btn-outline-danger btn-sm"
            data-action="header-image-picker#remove"
            data-header-image-picker-target="removeButton"
            style="<%= 'display: none;' unless current_image %>">
      Remove cover
    </button>

    <!-- Emoji Picker Popover -->
    <div data-header-image-picker-target="emojiPicker" class="emoji-picker" style="display: none;">
      <div class="emoji-picker-scroll">
        <% {
          "Smileys" => %w[рЯША рЯШГ рЯШД рЯШБ рЯШЖ рЯШЕ рЯ§£ рЯШВ рЯЩВ рЯЩГ рЯШЙ рЯШК рЯШЗ рЯ•∞ рЯШН рЯ§© рЯШШ рЯШЧ рЯШЪ рЯШЩ рЯ•≤ рЯШЛ рЯШЫ рЯШЬ рЯ§™ рЯШЭ рЯ§С рЯ§Ч рЯ§≠ рЯ§Ђ рЯ§Ф рЯ§Р рЯ§® рЯШР рЯШС рЯШґ рЯШП рЯШТ рЯЩД рЯШђ рЯ§• рЯШМ рЯШФ рЯШ™ рЯ§§ рЯШі рЯШЈ рЯ§Т рЯ§Х рЯ§Ґ рЯ§Ѓ рЯ§І рЯ•µ рЯ•ґ рЯ•і рЯШµ рЯ§ѓ рЯ§† рЯ•≥ рЯ•Є рЯШО рЯ§У рЯІР рЯШХ рЯШЯ рЯЩБ вШєпЄП рЯШЃ рЯШѓ рЯШ≤ рЯШ≥ рЯ•Ї рЯШ¶ рЯШІ рЯШ® рЯШ∞ рЯШ• рЯШҐ рЯШ≠ рЯШ± рЯШЦ рЯШ£ рЯШЮ рЯШУ рЯШ© рЯШЂ рЯ•± рЯШ§ рЯШ° рЯШ† рЯ§ђ рЯШИ рЯСњ рЯТА вШ†пЄП рЯТ© рЯ§° рЯСє рЯСЇ рЯСї рЯСљ рЯСЊ рЯ§Ц],
          "Gestures" => %w[рЯСЛ рЯ§Ъ рЯЦР вЬЛ рЯЦЦ рЯСМ рЯ§М рЯ§П вЬМпЄП рЯ§Ю рЯ§Я рЯ§Ш рЯ§Щ рЯСИ рЯСЙ рЯСЖ рЯЦХ рЯСЗ вШЭпЄП рЯСН рЯСО вЬК рЯСК рЯ§Ы рЯ§Ь рЯСП рЯЩМ рЯСР рЯ§≤ рЯ§Э рЯЩП вЬНпЄП рЯТЕ рЯ§≥ рЯТ™ рЯ¶Њ рЯ¶њ рЯ¶µ рЯ¶ґ рЯСВ рЯ¶ї рЯСГ рЯІ† рЯЂА рЯЂБ рЯ¶Ј рЯ¶і рЯСА рЯСБ рЯСЕ рЯСД],
          "People" => %w[рЯСґ рЯІТ рЯС¶ рЯСІ рЯІС рЯС± рЯС® рЯІФ рЯС© рЯІУ рЯСі рЯСµ рЯЩН рЯЩО рЯЩЕ рЯЩЖ рЯТБ рЯЩЛ рЯІП рЯЩЗ рЯ§¶ рЯ§Ј рЯСЃ рЯХµ рЯТВ рЯ•Ј рЯСЈ рЯ§і рЯСЄ рЯС≥ рЯС≤ рЯІХ рЯ§µ рЯС∞ рЯ§∞ рЯ§± рЯСЉ рЯОЕ рЯ§ґ рЯ¶Є рЯ¶є рЯІЩ рЯІЪ рЯІЫ рЯІЬ рЯІЭ рЯІЮ рЯІЯ рЯТЖ рЯТЗ рЯЪґ рЯІН рЯІО рЯПГ рЯТГ рЯХЇ рЯСѓ рЯІЦ рЯІЧ рЯ§Є рЯПМ рЯПЗ вЫЈ рЯПВ рЯПЛ рЯ§Љ рЯ§љ рЯ§Њ рЯ§Ї вЫє рЯПК рЯЪ£ рЯІШ рЯЫА рЯЫМ],
          "Animals" => %w[рЯРґ рЯР± рЯР≠ рЯРє рЯР∞ рЯ¶К рЯРї рЯРЉ рЯРївАНвЭДпЄП рЯР® рЯРѓ рЯ¶Б рЯРЃ рЯРЈ рЯРљ рЯРЄ рЯРµ рЯЩИ рЯЩЙ рЯЩК рЯРТ рЯРФ рЯРІ рЯР¶ рЯР§ рЯР£ рЯР• рЯ¶Ж рЯ¶Е рЯ¶Й рЯ¶З рЯРЇ рЯРЧ рЯРі рЯ¶Д рЯРЭ рЯ™± рЯРЫ рЯ¶Л рЯРМ рЯРЮ рЯРЬ рЯ™∞ рЯ™≤ рЯ™≥ рЯ¶Я рЯ¶Ч рЯХЈ рЯХЄ рЯ¶В рЯРҐ рЯРН рЯ¶О рЯ¶Ц рЯ¶Х рЯРЩ рЯ¶С рЯ¶Р рЯ¶Ю рЯ¶А рЯР° рЯР† рЯРЯ рЯРђ рЯР≥ рЯРЛ рЯ¶И рЯРК рЯРЕ рЯРЖ рЯ¶У рЯ¶Н рЯ¶І рЯ¶£ рЯРШ рЯ¶Ы рЯ¶П рЯР™ рЯРЂ рЯ¶Т рЯ¶Ш рЯ¶ђ рЯРГ рЯРВ рЯРД рЯРО рЯРЦ рЯРП рЯРС рЯ¶Щ рЯРР рЯ¶М рЯРХ рЯР© рЯ¶Ѓ рЯРХвАНрЯ¶Ї рЯРИ рЯРИвАНвђЫ рЯ™ґ рЯРУ рЯ¶Г рЯ¶§ рЯ¶Ъ рЯ¶Ь рЯ¶Ґ рЯ¶© рЯХК рЯРЗ рЯ¶Э рЯ¶® рЯ¶° рЯ¶Ђ рЯ¶¶ рЯ¶• рЯРБ рЯРА рЯРњ рЯ¶Ф],
          "Nature" => %w[рЯМµ рЯОД рЯМ≤ рЯМ≥ рЯМі рЯ™µ рЯМ± рЯМњ вШШпЄП рЯНА рЯОН рЯ™і рЯОЛ рЯНГ рЯНВ рЯНБ рЯНД рЯРЪ рЯ™® рЯМЊ рЯТР рЯМЈ рЯМє рЯ•А рЯМЇ рЯМЄ рЯМЉ рЯМї рЯМЮ рЯМЭ рЯМЫ рЯМЬ рЯМЪ рЯМХ рЯМЦ рЯМЧ рЯМШ рЯМС рЯМТ рЯМУ рЯМФ рЯМЩ рЯМО рЯМН рЯМП рЯ™Р рЯТЂ в≠Р рЯМЯ вЬ® вЪ° вШДпЄП рЯТ• рЯФ• рЯМ™ рЯМИ вШАпЄП рЯМ§ вЫЕ рЯМ• вШБпЄП рЯМ¶ рЯМІ вЫИ рЯМ© рЯМ® вЭДпЄП вШГпЄП вЫД рЯМђ рЯТ® рЯТІ рЯТ¶ вШФ вШВпЄП рЯМК рЯМЂ],
          "Food" => %w[рЯНП рЯНО рЯНР рЯНК рЯНЛ рЯНМ рЯНЙ рЯНЗ рЯНУ рЯЂР рЯНИ рЯНТ рЯНС рЯ•≠ рЯНН рЯ•• рЯ•Э рЯНЕ рЯНЖ рЯ•С рЯ•¶ рЯ•ђ рЯ•Т рЯМґ рЯЂС рЯМљ рЯ•Х рЯЂТ рЯІД рЯІЕ рЯ•Ф рЯН† рЯ•Р рЯ•ѓ рЯНЮ рЯ•Ц рЯ•® рЯІА рЯ•Ъ рЯН≥ рЯІИ рЯ•Ю рЯІЗ рЯ•У рЯ•© рЯНЧ рЯНЦ рЯ¶і рЯМ≠ рЯНФ рЯНЯ рЯНХ рЯЂУ рЯ•™ рЯ•Щ рЯІЖ рЯМЃ рЯМѓ рЯЂФ рЯ•Ч рЯ•Ш рЯЂХ рЯ•Ђ рЯНЭ рЯНЬ рЯН≤ рЯНЫ рЯН£ рЯН± рЯ•Я рЯ¶™ рЯН§ рЯНЩ рЯНЪ рЯНШ рЯН• рЯ•† рЯ•Ѓ рЯНҐ рЯН° рЯНІ рЯН® рЯН¶ рЯ•І рЯІБ рЯН∞ рЯОВ рЯНЃ рЯН≠ рЯНђ рЯНЂ рЯНњ рЯН© рЯН™ рЯМ∞ рЯ•Ь рЯНѓ рЯ•Ы рЯНЉ рЯЂЦ вШХ рЯНµ рЯІГ рЯ•§ рЯІЛ рЯНґ рЯНЇ рЯНї рЯ•В рЯНЈ рЯ•Г рЯНЄ рЯНє рЯІЙ рЯНЊ рЯІК рЯ•Д рЯНі рЯНљ рЯ•£ рЯ•° рЯ•Ґ рЯІВ],
          "Activities" => %w[вЪљ рЯПА рЯПИ вЪЊ рЯ•О рЯОЊ рЯПР рЯПЙ рЯ•П рЯО± рЯ™А рЯПУ рЯПЄ рЯПТ рЯПС рЯ•Н рЯПП рЯ™Г рЯ•Е вЫ≥ рЯ™Б рЯПє рЯО£ рЯ§њ рЯ•К рЯ•Л рЯОљ рЯЫє рЯЫЉ рЯЫЈ вЫЄ рЯ•М рЯОњ вЫЈ рЯПВ рЯ™В рЯПЛ рЯ§Љ рЯ§Є рЯ§Ї вЫє рЯ§Њ рЯПМ рЯПЗ рЯІШ рЯПД рЯПК рЯ§љ рЯЪ£ рЯІЧ рЯЪµ рЯЪі рЯПЖ рЯ•З рЯ•И рЯ•Й рЯПЕ рЯОЦ рЯПµ рЯОЧ рЯОЂ рЯОЯ рЯО™ рЯ§є рЯО≠ рЯ©∞ рЯО® рЯОђ рЯО§ рЯОІ рЯОЉ рЯОє рЯ•Б рЯ™Ш рЯОЈ рЯОЇ рЯОЄ рЯ™Х рЯОї рЯ™Ч рЯО≤ вЩЯ рЯОѓ рЯО≥ рЯОЃ рЯО∞ рЯІ©],
          "Travel" => %w[рЯЪЧ рЯЪХ рЯЪЩ рЯЪМ рЯЪО рЯПО рЯЪУ рЯЪС рЯЪТ рЯЪР рЯЫї рЯЪЪ рЯЪЫ рЯЪЬ рЯ¶ѓ рЯ¶љ рЯ¶Љ рЯЫі рЯЪ≤ рЯЫµ рЯПН рЯЫЇ рЯЪ® рЯЪФ рЯЪН рЯЪШ рЯЪЦ рЯЪ° рЯЪ† рЯЪЯ рЯЪГ рЯЪЛ рЯЪЮ рЯЪЭ рЯЪД рЯЪЕ рЯЪИ рЯЪВ рЯЪЖ рЯЪЗ рЯЪК рЯЪЙ вЬИпЄП рЯЫЂ рЯЫђ рЯЫ© рЯТЇ рЯЫ∞ рЯЪА рЯЫЄ рЯЪБ рЯЫґ вЫµ рЯЪ§ рЯЫ• рЯЫ≥ вЫі рЯЪҐ вЪУ рЯ™Э вЫљ рЯЪІ рЯЪ¶ рЯЪ• рЯЪП рЯЧЇ рЯЧњ рЯЧљ рЯЧЉ рЯП∞ рЯПѓ рЯПЯ рЯО° рЯОҐ рЯО† вЫ≤ вЫ± рЯПЦ рЯПЭ рЯПЬ рЯМЛ вЫ∞ рЯПФ рЯЧї рЯПХ вЫЇ рЯЫЦ рЯП† рЯП° рЯПШ рЯПЪ рЯПЧ рЯП≠ рЯПҐ рЯПђ рЯП£ рЯП§ рЯП• рЯП¶ рЯП® рЯП™ рЯПЂ рЯП© рЯТТ рЯПЫ вЫ™ рЯХМ рЯХН рЯЫХ рЯХЛ вЫ© рЯЫ§ рЯЫ£ рЯЧЊ рЯОС рЯПЮ рЯМЕ рЯМД рЯМ† рЯОЗ рЯОЖ рЯМЗ рЯМЖ рЯПЩ рЯМГ рЯММ рЯМЙ рЯМБ],
          "Objects" => %w[вМЪ рЯУ± рЯУ≤ рЯТї вМ®пЄП рЯЦ• рЯЦ® рЯЦ± рЯЦ≤ рЯХє рЯЧЬ рЯТљ рЯТЊ рЯТњ рЯУА рЯУЉ рЯУЈ рЯУЄ рЯУє рЯО• рЯУљ рЯОЮ рЯУЮ вШОпЄП рЯУЯ рЯУ† рЯУЇ рЯУї рЯОЩ рЯОЪ рЯОЫ рЯІ≠ вП± вП≤ вП∞ рЯХ∞ вМЫ вП≥ рЯУ° рЯФЛ рЯФМ рЯТ° рЯФ¶ рЯХѓ рЯ™Ф рЯІѓ рЯЫҐ рЯТЄ рЯТµ рЯТі рЯТґ рЯТЈ рЯ™Щ рЯТ∞ рЯТ≥ рЯТО вЪЦпЄП рЯ™Ь рЯІ∞ рЯ™Ы рЯФІ рЯФ® вЪТ рЯЫ† вЫП рЯ™Ъ рЯФ© вЪЩпЄП рЯ™§ рЯІ± вЫУ рЯІ≤ рЯФЂ рЯТ£ рЯІ® рЯ™У рЯФ™ рЯЧ° вЪФпЄП рЯЫ° рЯЪђ вЪ∞пЄП рЯ™¶ вЪ±пЄП рЯПЇ рЯФЃ рЯУњ рЯІњ рЯТИ вЪЧпЄП рЯФ≠ рЯФђ рЯХ≥ рЯ©є рЯ©Ї рЯТК рЯТЙ рЯ©Є рЯІђ рЯ¶† рЯІЂ рЯІ™ рЯМ° рЯІє рЯ™† рЯІЇ рЯІї рЯЪљ рЯЪ∞ рЯЪњ рЯЫБ рЯЫА рЯІЉ рЯ™• рЯ™Т рЯІљ рЯ™£ рЯІі рЯЫО рЯФС рЯЧЭ рЯЪ™ рЯ™С рЯЫЛ рЯЫП рЯЫМ рЯІЄ рЯ™Ж рЯЦЉ рЯ™Ю рЯ™Я рЯЫН рЯЫТ рЯОБ рЯОИ рЯОП рЯОА рЯ™Д рЯ™Е рЯОК рЯОЙ рЯОО рЯПЃ рЯОР рЯІІ вЬЙпЄП рЯУ© рЯУ® рЯУІ рЯТМ рЯУ• рЯУ§ рЯУ¶ рЯПЈ рЯ™І рЯУ™ рЯУЂ рЯУђ рЯУ≠ рЯУЃ рЯУѓ рЯУЬ рЯУГ рЯУД рЯУС рЯІЊ рЯУК рЯУИ рЯУЙ рЯЧТ рЯЧУ рЯУЖ рЯУЕ рЯЧС рЯУЗ рЯЧГ рЯЧ≥ рЯЧД рЯУЛ рЯУБ рЯУВ рЯЧВ рЯЧЮ рЯУ∞ рЯУУ рЯУФ рЯУТ рЯУХ рЯУЧ рЯУШ рЯУЩ рЯУЪ рЯУЦ рЯФЦ рЯІЈ рЯФЧ рЯУО рЯЦЗ рЯУР рЯУП рЯІЃ рЯУМ рЯУН вЬВпЄП рЯЦК рЯЦЛ вЬТпЄП рЯЦМ рЯЦН рЯУЭ вЬПпЄП рЯФН рЯФО рЯФП рЯФР рЯФТ рЯФУ],
