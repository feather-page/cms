<div class="mb-3"
     data-controller="header-image-picker"
     data-header-image-picker-search-url-value="<%= search_url %>"
     data-header-image-picker-create-url-value="<%= create_url %>"
     data-header-image-picker-upload-url-value="<%= upload_url %>">

  <%= form.hidden_field attribute, data: { header_image_picker_target: "coverInput" } %>
  <%= form.hidden_field thumbnail_attribute, data: { header_image_picker_target: "thumbnailInput" } %>
  <%= form.hidden_field emoji_attribute, data: { header_image_picker_target: "emojiInput" } %>

  <!-- Preview Area -->
  <div data-header-image-picker-target="preview" class="header-preview mb-3" style="<%= 'display: none;' unless current_image || current_thumbnail || current_emoji.present? %>">
    <!-- Thumbnail Preview -->
    <div class="thumbnail-preview" data-header-image-picker-target="thumbnailContainer" style="<%= 'display: none;' unless current_thumbnail %>">
      <% if current_thumbnail %>
        <%= image_tag current_thumbnail.file %>
      <% end %>
    </div>

    <!-- Cover Preview -->
    <div class="header-preview-image" data-header-image-picker-target="imageContainer" style="<%= 'display: none;' unless current_image %>">
      <% if current_image %>
        <%= image_tag current_image.file %>
      <% end %>
    </div>

    <!-- Emoji Preview -->
    <% if current_emoji.present? %>
      <button type="button"
              class="header-preview-emoji"
              data-header-image-picker-target="emojiDisplay"
              data-action="header-image-picker#openEmojiPicker"
              title="Click to change icon"><%= current_emoji %></button>
    <% else %>
      <span class="header-preview-emoji" data-header-image-picker-target="emojiDisplay" style="display: none;"></span>
    <% end %>
  </div>

  <!-- Action Buttons -->
  <div class="d-flex gap-2 flex-wrap mb-3 position-relative">
    <!-- Icon Button (standalone) -->
    <button type="button"
            class="btn btn-outline-secondary btn-sm"
            data-action="header-image-picker#openEmojiPicker"
            data-header-image-picker-target="addIconButton">
      рҹҳҖ Add icon
    </button>
    <button type="button"
            class="btn btn-outline-danger btn-sm"
            data-action="header-image-picker#removeEmoji"
            data-header-image-picker-target="removeEmojiButton"
            style="<%= 'display: none;' unless current_emoji.present? %>">
      Remove icon
    </button>

    <!-- Thumbnail Button Group -->
    <div class="btn-group" role="group">
      <button type="button"
              class="btn btn-outline-secondary btn-sm"
              data-action="header-image-picker#openUnsplashForThumbnail">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-image me-1" viewBox="0 0 16 16">
          <path d="M6.002 5.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0"/>
          <path d="M2.002 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2zm12 1a1 1 0 0 1 1 1v6.5l-3.777-1.947a.5.5 0 0 0-.577.093l-3.71 3.71-2.66-1.772a.5.5 0 0 0-.63.062L1.002 12V3a1 1 0 0 1 1-1z"/>
        </svg>
        Thumbnail
      </button>

      <button type="button"
              class="btn btn-outline-secondary btn-sm"
              data-action="header-image-picker#openUploadForThumbnail">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-upload me-1" viewBox="0 0 16 16">
          <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5"/>
          <path d="M7.646 1.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1-.708.708L8.5 2.707V11.5a.5.5 0 0 1-1 0V2.707L5.354 4.854a.5.5 0 1 1-.708-.708z"/>
        </svg>
        Upload
      </button>
    </div>

    <button type="button"
            class="btn btn-outline-danger btn-sm"
            data-action="header-image-picker#removeThumbnail"
            data-header-image-picker-target="removeThumbnailButton"
            style="<%= 'display: none;' unless current_thumbnail %>">
      Remove thumbnail
    </button>

    <!-- Cover Button Group -->
    <div class="btn-group" role="group">
      <button type="button"
              class="btn btn-outline-secondary btn-sm"
              data-action="header-image-picker#openUnsplashForCover">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-image me-1" viewBox="0 0 16 16">
          <path d="M6.002 5.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0"/>
          <path d="M2.002 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2zm12 1a1 1 0 0 1 1 1v6.5l-3.777-1.947a.5.5 0 0 0-.577.093l-3.71 3.71-2.66-1.772a.5.5 0 0 0-.63.062L1.002 12V3a1 1 0 0 1 1-1z"/>
        </svg>
        Cover
      </button>

      <button type="button"
              class="btn btn-outline-secondary btn-sm"
              data-action="header-image-picker#openUploadForCover">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-upload me-1" viewBox="0 0 16 16">
          <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5"/>
          <path d="M7.646 1.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1-.708.708L8.5 2.707V11.5a.5.5 0 0 1-1 0V2.707L5.354 4.854a.5.5 0 1 1-.708-.708z"/>
        </svg>
        Upload
      </button>
    </div>

    <button type="button"
            class="btn btn-outline-danger btn-sm"
            data-action="header-image-picker#remove"
            data-header-image-picker-target="removeButton"
            style="<%= 'display: none;' unless current_image %>">
      Remove cover
    </button>

    <!-- Emoji Picker Popover -->
    <div data-header-image-picker-target="emojiPicker" class="emoji-picker" style="display: none;">
      <div class="emoji-picker-scroll">
        <% {
          "Smileys" => %w[рҹҳҖ рҹҳғ рҹҳ„ рҹҳҒ рҹҳҶ рҹҳ… рҹӨЈ рҹҳӮ рҹҷӮ рҹҷғ рҹҳү рҹҳҠ рҹҳҮ рҹҘ° рҹҳҚ рҹӨ© рҹҳҳ рҹҳ— рҹҳҡ рҹҳҷ рҹҘІ рҹҳӢ рҹҳӣ рҹҳң рҹӨӘ рҹҳқ рҹӨ‘ рҹӨ— рҹӨӯ рҹӨ« рҹӨ” рҹӨҗ рҹӨЁ рҹҳҗ рҹҳ‘ рҹҳ¶ рҹҳҸ рҹҳ’ рҹҷ„ рҹҳ¬ рҹӨҘ рҹҳҢ рҹҳ” рҹҳӘ рҹӨӨ рҹҳҙ рҹҳ· рҹӨ’ рҹӨ• рҹӨў рҹӨ® рҹӨ§ рҹҘө рҹҘ¶ рҹҘҙ рҹҳө рҹӨҜ рҹӨ  рҹҘі рҹҘё рҹҳҺ рҹӨ“ рҹ§җ рҹҳ• рҹҳҹ рҹҷҒ вҳ№пёҸ рҹҳ® рҹҳҜ рҹҳІ рҹҳі рҹҘә рҹҳҰ рҹҳ§ рҹҳЁ рҹҳ° рҹҳҘ рҹҳў рҹҳӯ рҹҳұ рҹҳ– рҹҳЈ рҹҳһ рҹҳ“ рҹҳ© рҹҳ« рҹҘұ рҹҳӨ рҹҳЎ рҹҳ  рҹӨ¬ рҹҳҲ рҹ‘ҝ рҹ’Җ вҳ пёҸ рҹ’© рҹӨЎ рҹ‘№ рҹ‘ә рҹ‘» рҹ‘Ҫ рҹ‘ҫ рҹӨ–],
          "Gestures" => %w[рҹ‘Ӣ рҹӨҡ рҹ–җ вңӢ рҹ–– рҹ‘Ң рҹӨҢ рҹӨҸ вңҢпёҸ рҹӨһ рҹӨҹ рҹӨҳ рҹӨҷ рҹ‘Ҳ рҹ‘ү рҹ‘Ҷ рҹ–• рҹ‘Ү вҳқпёҸ рҹ‘Қ рҹ‘Һ вңҠ рҹ‘Ҡ рҹӨӣ рҹӨң рҹ‘Ҹ рҹҷҢ рҹ‘җ рҹӨІ рҹӨқ рҹҷҸ вңҚпёҸ рҹ’… рҹӨі рҹ’Ә рҹҰҫ рҹҰҝ рҹҰө рҹҰ¶ рҹ‘Ӯ рҹҰ» рҹ‘ғ рҹ§  рҹ«Җ рҹ«Ғ рҹҰ· рҹҰҙ рҹ‘Җ рҹ‘Ғ рҹ‘… рҹ‘„],
          "People" => %w[рҹ‘¶ рҹ§’ рҹ‘Ұ рҹ‘§ рҹ§‘ рҹ‘ұ рҹ‘Ё рҹ§” рҹ‘© рҹ§“ рҹ‘ҙ рҹ‘ө рҹҷҚ рҹҷҺ рҹҷ… рҹҷҶ рҹ’Ғ рҹҷӢ рҹ§Ҹ рҹҷҮ рҹӨҰ рҹӨ· рҹ‘® рҹ•ө рҹ’Ӯ рҹҘ· рҹ‘· рҹӨҙ рҹ‘ё рҹ‘і рҹ‘І рҹ§• рҹӨө рҹ‘° рҹӨ° рҹӨұ рҹ‘ј рҹҺ… рҹӨ¶ рҹҰё рҹҰ№ рҹ§ҷ рҹ§ҡ рҹ§ӣ рҹ§ң рҹ§қ рҹ§һ рҹ§ҹ рҹ’Ҷ рҹ’Ү рҹҡ¶ рҹ§Қ рҹ§Һ рҹҸғ рҹ’ғ рҹ•ә рҹ‘Ҝ рҹ§– рҹ§— рҹӨё рҹҸҢ рҹҸҮ вӣ· рҹҸӮ рҹҸӢ рҹӨј рҹӨҪ рҹӨҫ рҹӨә вӣ№ рҹҸҠ рҹҡЈ рҹ§ҳ рҹӣҖ рҹӣҢ],
          "Animals" => %w[рҹҗ¶ рҹҗұ рҹҗӯ рҹҗ№ рҹҗ° рҹҰҠ рҹҗ» рҹҗј рҹҗ»вҖҚвқ„пёҸ рҹҗЁ рҹҗҜ рҹҰҒ рҹҗ® рҹҗ· рҹҗҪ рҹҗё рҹҗө рҹҷҲ рҹҷү рҹҷҠ рҹҗ’ рҹҗ” рҹҗ§ рҹҗҰ рҹҗӨ рҹҗЈ рҹҗҘ рҹҰҶ рҹҰ… рҹҰү рҹҰҮ рҹҗә рҹҗ— рҹҗҙ рҹҰ„ рҹҗқ рҹӘұ рҹҗӣ рҹҰӢ рҹҗҢ рҹҗһ рҹҗң рҹӘ° рҹӘІ рҹӘі рҹҰҹ рҹҰ— рҹ•· рҹ•ё рҹҰӮ рҹҗў рҹҗҚ рҹҰҺ рҹҰ– рҹҰ• рҹҗҷ рҹҰ‘ рҹҰҗ рҹҰһ рҹҰҖ рҹҗЎ рҹҗ  рҹҗҹ рҹҗ¬ рҹҗі рҹҗӢ рҹҰҲ рҹҗҠ рҹҗ… рҹҗҶ рҹҰ“ рҹҰҚ рҹҰ§ рҹҰЈ рҹҗҳ рҹҰӣ рҹҰҸ рҹҗӘ рҹҗ« рҹҰ’ рҹҰҳ рҹҰ¬ рҹҗғ рҹҗӮ рҹҗ„ рҹҗҺ рҹҗ– рҹҗҸ рҹҗ‘ рҹҰҷ рҹҗҗ рҹҰҢ рҹҗ• рҹҗ© рҹҰ® рҹҗ•вҖҚрҹҰә рҹҗҲ рҹҗҲвҖҚв¬ӣ рҹӘ¶ рҹҗ“ рҹҰғ рҹҰӨ рҹҰҡ рҹҰң рҹҰў рҹҰ© рҹ•Ҡ рҹҗҮ рҹҰқ рҹҰЁ рҹҰЎ рҹҰ« рҹҰҰ рҹҰҘ рҹҗҒ рҹҗҖ рҹҗҝ рҹҰ”],
          "Nature" => %w[рҹҢө рҹҺ„ рҹҢІ рҹҢі рҹҢҙ рҹӘө рҹҢұ рҹҢҝ вҳҳпёҸ рҹҚҖ рҹҺҚ рҹӘҙ рҹҺӢ рҹҚғ рҹҚӮ рҹҚҒ рҹҚ„ рҹҗҡ рҹӘЁ рҹҢҫ рҹ’җ рҹҢ· рҹҢ№ рҹҘҖ рҹҢә рҹҢё рҹҢј рҹҢ» рҹҢһ рҹҢқ рҹҢӣ рҹҢң рҹҢҡ рҹҢ• рҹҢ– рҹҢ— рҹҢҳ рҹҢ‘ рҹҢ’ рҹҢ“ рҹҢ” рҹҢҷ рҹҢҺ рҹҢҚ рҹҢҸ рҹӘҗ рҹ’« вӯҗ рҹҢҹ вңЁ вҡЎ вҳ„пёҸ рҹ’Ҙ рҹ”Ҙ рҹҢӘ рҹҢҲ вҳҖпёҸ рҹҢӨ вӣ… рҹҢҘ вҳҒпёҸ рҹҢҰ рҹҢ§ вӣҲ рҹҢ© рҹҢЁ вқ„пёҸ вҳғпёҸ вӣ„ рҹҢ¬ рҹ’Ё рҹ’§ рҹ’Ұ вҳ” вҳӮпёҸ рҹҢҠ рҹҢ«],
          "Food" => %w[рҹҚҸ рҹҚҺ рҹҚҗ рҹҚҠ рҹҚӢ рҹҚҢ рҹҚү рҹҚҮ рҹҚ“ рҹ«җ рҹҚҲ рҹҚ’ рҹҚ‘ рҹҘӯ рҹҚҚ рҹҘҘ рҹҘқ рҹҚ… рҹҚҶ рҹҘ‘ рҹҘҰ рҹҘ¬ рҹҘ’ рҹҢ¶ рҹ«‘ рҹҢҪ рҹҘ• рҹ«’ рҹ§„ рҹ§… рҹҘ” рҹҚ  рҹҘҗ рҹҘҜ рҹҚһ рҹҘ– рҹҘЁ рҹ§Җ рҹҘҡ рҹҚі рҹ§Ҳ рҹҘһ рҹ§Ү рҹҘ“ рҹҘ© рҹҚ— рҹҚ– рҹҰҙ рҹҢӯ рҹҚ” рҹҚҹ рҹҚ• рҹ«“ рҹҘӘ рҹҘҷ рҹ§Ҷ рҹҢ® рҹҢҜ рҹ«” рҹҘ— рҹҘҳ рҹ«• рҹҘ« рҹҚқ рҹҚң рҹҚІ рҹҚӣ рҹҚЈ рҹҚұ рҹҘҹ рҹҰӘ рҹҚӨ рҹҚҷ рҹҚҡ рҹҚҳ рҹҚҘ рҹҘ  рҹҘ® рҹҚў рҹҚЎ рҹҚ§ рҹҚЁ рҹҚҰ рҹҘ§ рҹ§Ғ рҹҚ° рҹҺӮ рҹҚ® рҹҚӯ рҹҚ¬ рҹҚ« рҹҚҝ рҹҚ© рҹҚӘ рҹҢ° рҹҘң рҹҚҜ рҹҘӣ рҹҚј рҹ«– вҳ• рҹҚө рҹ§ғ рҹҘӨ рҹ§Ӣ рҹҚ¶ рҹҚә рҹҚ» рҹҘӮ рҹҚ· рҹҘғ рҹҚё рҹҚ№ рҹ§ү рҹҚҫ рҹ§Ҡ рҹҘ„ рҹҚҙ рҹҚҪ рҹҘЈ рҹҘЎ рҹҘў рҹ§Ӯ],
          "Activities" => %w[вҡҪ рҹҸҖ рҹҸҲ вҡҫ рҹҘҺ рҹҺҫ рҹҸҗ рҹҸү рҹҘҸ рҹҺұ рҹӘҖ рҹҸ“ рҹҸё рҹҸ’ рҹҸ‘ рҹҘҚ рҹҸҸ рҹӘғ рҹҘ… вӣі рҹӘҒ рҹҸ№ рҹҺЈ рҹӨҝ рҹҘҠ рҹҘӢ рҹҺҪ рҹӣ№ рҹӣј рҹӣ· вӣё рҹҘҢ рҹҺҝ вӣ· рҹҸӮ рҹӘӮ рҹҸӢ рҹӨј рҹӨё рҹӨә вӣ№ рҹӨҫ рҹҸҢ рҹҸҮ рҹ§ҳ рҹҸ„ рҹҸҠ рҹӨҪ рҹҡЈ рҹ§— рҹҡө рҹҡҙ рҹҸҶ рҹҘҮ рҹҘҲ рҹҘү рҹҸ… рҹҺ– рҹҸө рҹҺ— рҹҺ« рҹҺҹ рҹҺӘ рҹӨ№ рҹҺӯ рҹ©° рҹҺЁ рҹҺ¬ рҹҺӨ рҹҺ§ рҹҺј рҹҺ№ рҹҘҒ рҹӘҳ рҹҺ· рҹҺә рҹҺё рҹӘ• рҹҺ» рҹӘ— рҹҺІ вҷҹ рҹҺҜ рҹҺі рҹҺ® рҹҺ° рҹ§©],
          "Travel" => %w[рҹҡ— рҹҡ• рҹҡҷ рҹҡҢ рҹҡҺ рҹҸҺ рҹҡ“ рҹҡ‘ рҹҡ’ рҹҡҗ рҹӣ» рҹҡҡ рҹҡӣ рҹҡң рҹҰҜ рҹҰҪ рҹҰј рҹӣҙ рҹҡІ рҹӣө рҹҸҚ рҹӣә рҹҡЁ рҹҡ” рҹҡҚ рҹҡҳ рҹҡ– рҹҡЎ рҹҡ  рҹҡҹ рҹҡғ рҹҡӢ рҹҡһ рҹҡқ рҹҡ„ рҹҡ… рҹҡҲ рҹҡӮ рҹҡҶ рҹҡҮ рҹҡҠ рҹҡү вңҲпёҸ рҹӣ« рҹӣ¬ рҹӣ© рҹ’ә рҹӣ° рҹҡҖ рҹӣё рҹҡҒ рҹӣ¶ вӣө рҹҡӨ рҹӣҘ рҹӣі вӣҙ рҹҡў вҡ“ рҹӘқ вӣҪ рҹҡ§ рҹҡҰ рҹҡҘ рҹҡҸ рҹ—ә рҹ—ҝ рҹ—Ҫ рҹ—ј рҹҸ° рҹҸҜ рҹҸҹ рҹҺЎ рҹҺў рҹҺ  вӣІ вӣұ рҹҸ– рҹҸқ рҹҸң рҹҢӢ вӣ° рҹҸ” рҹ—» рҹҸ• вӣә рҹӣ– рҹҸ  рҹҸЎ рҹҸҳ рҹҸҡ рҹҸ— рҹҸӯ рҹҸў рҹҸ¬ рҹҸЈ рҹҸӨ рҹҸҘ рҹҸҰ рҹҸЁ рҹҸӘ рҹҸ« рҹҸ© рҹ’’ рҹҸӣ вӣӘ рҹ•Ң рҹ•Қ рҹӣ• рҹ•Ӣ вӣ© рҹӣӨ рҹӣЈ рҹ—ҫ рҹҺ‘ рҹҸһ рҹҢ… рҹҢ„ рҹҢ  рҹҺҮ рҹҺҶ рҹҢҮ рҹҢҶ рҹҸҷ рҹҢғ рҹҢҢ рҹҢү рҹҢҒ],
          "Objects" => %w[вҢҡ рҹ“ұ рҹ“І рҹ’» вҢЁпёҸ рҹ–Ҙ рҹ–Ё рҹ–ұ рҹ–І рҹ•№ рҹ—ң рҹ’Ҫ рҹ’ҫ рҹ’ҝ рҹ“Җ рҹ“ј рҹ“· рҹ“ё рҹ“№ рҹҺҘ рҹ“Ҫ рҹҺһ рҹ“һ вҳҺпёҸ рҹ“ҹ рҹ“  рҹ“ә рҹ“» рҹҺҷ рҹҺҡ рҹҺӣ рҹ§ӯ вҸұ вҸІ вҸ° рҹ•° вҢӣ вҸі рҹ“Ў рҹ”Ӣ рҹ”Ң рҹ’Ў рҹ”Ұ рҹ•Ҝ рҹӘ” рҹ§Ҝ рҹӣў рҹ’ё рҹ’ө рҹ’ҙ рҹ’¶ рҹ’· рҹӘҷ рҹ’° рҹ’і рҹ’Һ вҡ–пёҸ рҹӘң рҹ§° рҹӘӣ рҹ”§ рҹ”Ё вҡ’ рҹӣ  вӣҸ рҹӘҡ рҹ”© вҡҷпёҸ рҹӘӨ рҹ§ұ вӣ“ рҹ§І рҹ”« рҹ’Ј рҹ§Ё рҹӘ“ рҹ”Ә рҹ—Ў вҡ”пёҸ рҹӣЎ рҹҡ¬ вҡ°пёҸ рҹӘҰ вҡұпёҸ рҹҸә рҹ”® рҹ“ҝ рҹ§ҝ рҹ’Ҳ вҡ—пёҸ рҹ”ӯ рҹ”¬ рҹ•і рҹ©№ рҹ©ә рҹ’Ҡ рҹ’ү рҹ©ё рҹ§¬ рҹҰ  рҹ§« рҹ§Ә рҹҢЎ рҹ§№ рҹӘ  рҹ§ә рҹ§» рҹҡҪ рҹҡ° рҹҡҝ рҹӣҒ рҹӣҖ рҹ§ј рҹӘҘ рҹӘ’ рҹ§Ҫ рҹӘЈ рҹ§ҙ рҹӣҺ рҹ”‘ рҹ—қ рҹҡӘ рҹӘ‘ рҹӣӢ рҹӣҸ рҹӣҢ рҹ§ё рҹӘҶ рҹ–ј рҹӘһ рҹӘҹ рҹӣҚ рҹӣ’ рҹҺҒ рҹҺҲ рҹҺҸ рҹҺҖ рҹӘ„ рҹӘ… рҹҺҠ рҹҺү рҹҺҺ рҹҸ® рҹҺҗ рҹ§§ вңүпёҸ рҹ“© рҹ“Ё рҹ“§ рҹ’Ң рҹ“Ҙ рҹ“Ө рҹ“Ұ рҹҸ· рҹӘ§ рҹ“Ә рҹ“« рҹ“¬ рҹ“ӯ рҹ“® рҹ“Ҝ рҹ“ң рҹ“ғ рҹ“„ рҹ“‘ рҹ§ҫ рҹ“Ҡ рҹ“Ҳ рҹ“ү рҹ—’ рҹ—“ рҹ“Ҷ рҹ“… рҹ—‘ рҹ“Ү рҹ—ғ рҹ—і рҹ—„ рҹ“Ӣ рҹ“Ғ рҹ“Ӯ рҹ—Ӯ рҹ—һ рҹ“° рҹ““ рҹ“” рҹ“’ рҹ“• рҹ“— рҹ“ҳ рҹ“ҷ рҹ“ҡ рҹ“– рҹ”– рҹ§· рҹ”— рҹ“Һ рҹ–Ү рҹ“җ рҹ“Ҹ рҹ§® рҹ“Ң рҹ“Қ вңӮпёҸ рҹ–Ҡ рҹ–Ӣ вң’пёҸ рҹ–Ң рҹ–Қ рҹ“қ вңҸпёҸ рҹ”Қ рҹ”Һ рҹ”Ҹ рҹ”җ рҹ”’ рҹ”“],
          "Symbols" => %w[вқӨпёҸ рҹ§Ў рҹ’ӣ рҹ’ҡ рҹ’ҷ рҹ’ң рҹ–Ө рҹӨҚ рҹӨҺ рҹ’” вқЈпёҸ рҹ’• рҹ’һ рҹ’“ рҹ’— рҹ’– рҹ’ҳ рҹ’қ рҹ’ҹ вҳ®пёҸ вңқпёҸ вҳӘпёҸ рҹ•ү вҳёпёҸ вңЎпёҸ рҹ”Ҝ рҹ•Һ вҳҜпёҸ вҳҰпёҸ рҹӣҗ вӣҺ вҷҲ вҷү вҷҠ вҷӢ вҷҢ вҷҚ вҷҺ вҷҸ вҷҗ вҷ‘ вҷ’ вҷ“ рҹҶ” вҡӣпёҸ рҹү‘ вҳўпёҸ вҳЈпёҸ рҹ“ҙ рҹ“і рҹҲ¶ рҹҲҡ рҹҲё рҹҲә рҹҲ·пёҸ вңҙпёҸ рҹҶҡ рҹ’® рҹүҗ гҠҷпёҸ гҠ—пёҸ рҹҲҙ рҹҲө рҹҲ№ рҹҲІ рҹ…°пёҸ рҹ…ұпёҸ рҹҶҺ рҹҶ‘ рҹ…ҫпёҸ рҹҶҳ вқҢ вӯ• рҹӣ‘ вӣ” рҹ“ӣ рҹҡ« рҹ’Ҝ рҹ’ў вҷЁпёҸ рҹҡ· рҹҡҜ рҹҡі рҹҡұ рҹ”һ рҹ“ө рҹҡӯ вқ— вқ• вқ“ вқ” вҖјпёҸ вҒүпёҸ рҹ”… рҹ”Ҷ гҖҪпёҸ вҡ пёҸ рҹҡё рҹ”ұ вҡңпёҸ рҹ”° вҷ»пёҸ вң… рҹҲҜ рҹ’№ вқҮпёҸ вңіпёҸ вқҺ рҹҢҗ рҹ’  в“ӮпёҸ рҹҢҖ рҹ’Ө рҹҸ§ рҹҡҫ вҷҝ рҹ…ҝпёҸ рҹӣ— рҹҲі рҹҲӮпёҸ рҹӣӮ рҹӣғ рҹӣ„ рҹӣ… рҹҡ№ рҹҡә рҹҡј вҡ§ рҹҡ» рҹҡ® рҹҺҰ рҹ“¶ рҹҲҒ рҹ”Ј в„№пёҸ рҹ”Ө рҹ”Ў рҹ”  рҹҶ– рҹҶ— рҹҶҷ рҹҶ’ рҹҶ• рҹҶ“ 0пёҸвғЈ 1пёҸвғЈ 2пёҸвғЈ 3пёҸвғЈ 4пёҸвғЈ 5пёҸвғЈ 6пёҸвғЈ 7пёҸвғЈ 8пёҸвғЈ 9пёҸвғЈ рҹ”ҹ рҹ”ў #пёҸвғЈ *пёҸвғЈ вҸҸпёҸ в–¶пёҸ вҸё вҸҜ вҸ№ вҸә вҸӯ вҸ® вҸ© вҸӘ вҸ« вҸ¬ в—ҖпёҸ рҹ”ј рҹ”Ҫ вһЎпёҸ в¬…пёҸ в¬ҶпёҸ в¬ҮпёҸ вҶ—пёҸ вҶҳпёҸ вҶҷпёҸ вҶ–пёҸ вҶ•пёҸ вҶ”пёҸ вҶӘпёҸ вҶ©пёҸ вӨҙпёҸ вӨөпёҸ рҹ”Җ рҹ”Ғ рҹ”Ӯ рҹ”„ рҹ”ғ рҹҺө рҹҺ¶ вһ• вһ– вһ— вң–пёҸ вҷҫ рҹ’І рҹ’ұ в„ўпёҸ В©пёҸ В®пёҸ гҖ°пёҸ вһ° вһҝ рҹ”ҡ рҹ”ҷ рҹ”ӣ рҹ”қ рҹ”ң вң”пёҸ вҳ‘пёҸ рҹ”ҳ рҹ”ҙ рҹҹ  рҹҹЎ рҹҹў рҹ”ө рҹҹЈ вҡ« вҡӘ рҹҹӨ рҹ”ә рҹ”» рҹ”ё рҹ”№ рҹ”¶ рҹ”· рҹ”і рҹ”І в–ӘпёҸ в–«пёҸ в—ҫ в—Ҫ в—јпёҸ в—»пёҸ рҹҹҘ рҹҹ§ рҹҹЁ рҹҹ© рҹҹҰ рҹҹӘ в¬ӣ в¬ң рҹҹ« рҹ”Ҳ рҹ”Ү рҹ”ү рҹ”Ҡ рҹ”” рҹ”• рҹ“Ј рҹ“ў рҹ‘ҒвҖҚрҹ—Ё рҹ’¬ рҹ’ӯ рҹ—Ҝ вҷ пёҸ вҷЈпёҸ вҷҘпёҸ вҷҰпёҸ рҹғҸ рҹҺҙ рҹҖ„ рҹ•җ рҹ•‘ рҹ•’ рҹ•“ рҹ•” рҹ•• рҹ•– рҹ•— рҹ•ҳ рҹ•ҷ рҹ•ҡ рҹ•ӣ рҹ•ң рҹ•қ рҹ•һ рҹ•ҹ рҹ•  рҹ•Ў рҹ•ў рҹ•Ј рҹ•Ө рҹ•Ҙ рҹ•Ұ рҹ•§],
          "Flags" => %w[рҹҸіпёҸ рҹҸҙ рҹҸҙвҖҚвҳ пёҸ рҹҸҒ рҹҡ© рҹҺҢ рҹҮ©рҹҮӘ рҹҮҰрҹҮ№ рҹҮЁрҹҮӯ рҹҮәрҹҮё рҹҮ¬рҹҮ§ рҹҮ«рҹҮ· рҹҮӘрҹҮё рҹҮ®рҹҮ№ рҹҮҜрҹҮө рҹҮЁрҹҮі рҹҮ°рҹҮ· рҹҮ·рҹҮә рҹҮ§рҹҮ· рҹҮ®рҹҮі рҹҮҰрҹҮә рҹҮЁрҹҮҰ рҹҮІрҹҮҪ рҹҮірҹҮұ рҹҮ§рҹҮӘ рҹҮёрҹҮӘ рҹҮірҹҮҙ рҹҮ©рҹҮ° рҹҮ«рҹҮ® рҹҮөрҹҮұ рҹҮәрҹҮҰ рҹҮ№рҹҮ· рҹҮ¬рҹҮ· рҹҮөрҹҮ№ рҹҮ®рҹҮӘ рҹҮҝрҹҮҰ рҹҮӘрҹҮ¬ рҹҮірҹҮ¬ рҹҮ°рҹҮӘ рҹҮҰрҹҮ· рҹҮЁрҹҮұ рҹҮЁрҹҮҙ рҹҮөрҹҮӘ рҹҮ»рҹҮӘ рҹҮ№рҹҮӯ рҹҮ»рҹҮі рҹҮ®рҹҮ© рҹҮөрҹҮӯ рҹҮІрҹҮҫ рҹҮёрҹҮ¬ рҹҮірҹҮҝ рҹҮ®рҹҮұ рҹҮёрҹҮҰ рҹҮҰрҹҮӘ рҹҮ¶рҹҮҰ рҹҮӘрҹҮә]
        }.each do |category, emojis| %>
          <div class="emoji-category">
            <div class="emoji-category-label"><%= category %></div>
            <div class="emoji-picker-grid">
              <% emojis.each do |emoji| %>
                <button type="button"
                        class="emoji-option"
                        data-action="header-image-picker#selectEmoji"
                        data-emoji="<%= emoji %>"><%= emoji %></button>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Unsplash Search Modal -->
  <dialog data-header-image-picker-target="unsplashModal"
          class="p-0 border-0 rounded">
    <div class="card shadow-sm" style="width: 800px; max-width: 90vw;">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="m-0">Search Unsplash</h5>
        <button type="button"
                class="btn-close"
                data-action="header-image-picker#closeUnsplashModal">
        </button>
      </div>
      <div class="card-body">
        <input type="text"
               class="form-control mb-3"
               placeholder="Search for images..."
               data-header-image-picker-target="searchInput"
               data-action="input->header-image-picker#search">

        <div data-header-image-picker-target="loading"
             class="text-center mb-3"
             style="display: none;">
          <div class="spinner-border spinner-border-sm" role="status">
            <span class="visually-hidden">Loading...</span>
          </div>
        </div>

        <div data-header-image-picker-target="results"
             class="row g-3"
             style="max-height: 400px; overflow-y: auto;">
        </div>
      </div>
    </div>
  </dialog>

  <!-- Upload Modal -->
  <dialog data-header-image-picker-target="uploadModal"
          class="p-0 border-0 rounded">
    <div class="card shadow-sm" style="width: 500px; max-width: 90vw;">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="m-0">Upload Image</h5>
        <button type="button"
                class="btn-close"
                data-action="header-image-picker#closeUploadModal">
        </button>
      </div>
      <div class="card-body">
        <input type="file"
               class="form-control"
               accept="image/*"
               data-header-image-picker-target="fileInput"
               data-action="change->header-image-picker#upload">
        <div class="form-text">Max file size: 25MB</div>
      </div>
    </div>
  </dialog>
</div>

