<div class="alert alert--<%= @variant %>" role="alert"<% if dismissible? %> data-controller="notice"<% end %>>
  <div class="alert__content"><%= content %></div>
  <% if dismissible? %>
    <button type="button" class="alert__dismiss" aria-label="Dismiss" data-action="click->notice#close">&times;</button>
  <% end %>
</div>
