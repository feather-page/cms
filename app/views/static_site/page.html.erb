<%= static_site_content_html(@page.static_site_html) %>

<% if @page.tag_list.any? %>
  <div class="page-tags">
    <% @page.tag_list.each do |tag| %>
      <span class="badge badge-outline"><%= tag %></span>
    <% end %>
  </div>
<% end %>

<% if @page.page_type_books? %>
  <%= render StaticSite::BooksListComponent.new(books: @page.site.books.ordered) %>
<% end %>

<% if @page.page_type_projects? %>
  <%= render StaticSite::ProjectsListComponent.new(projects: @page.site.projects.ordered, base_url: @base_url || "/") %>
<% end %>
