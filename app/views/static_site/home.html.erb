<ul class="page-list">
  <% @site.main_navigation.navigation_items.ordered.each do |item| %>
    <li>
      <%= item.emoji %> <a class="page-link" href="<%= @base_url %><%= item.slug.sub(%r{^/}, '') %>/"><%= item.title %></a>
    </li>
  <% end %>
</ul>

<%= static_site_content_html(@page&.static_site_html.to_s) %>

<hr />

<h2>Blogposts</h2>

<div class="page-list">
  <% @site.posts.published.order(publish_at: :desc).each do |post| %>
    <article>
      <% if post.title.blank? %>
        <%# Short post without title %>
        <% if post.book.present? %>
          <div class="book-card book-card--detail">
            <div class="book-card-header">
              <% if static_site_image_url(post.book.cover_image, :mobile_x1) %>
                <img src="<%= static_site_image_url(post.book.cover_image, :mobile_x1) %>" alt="<%= post.book.title %>" class="book-cover" loading="lazy">
              <% elsif post.book.emoji.present? %>
                <span class="book-emoji"><%= post.book.emoji %></span>
              <% end %>
              <div class="book-info">
                <div class="book-title"><%= post.book.title %></div>
                <div class="book-author"><%= post.book.author %></div>
                <% if post.book.rating.present? %>
                  <div class="book-rating" aria-label="<%= post.book.rating %> out of 5 stars"><%= static_site_rating_stars(post.book.rating) %></div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
        <div class="post-shortBody">
          <% if post.emoji.present? && post.book.blank? %>
            <div class="post-emoji"><%= post.emoji %></div>
          <% end %>
          <div class="post-content"><%= static_site_content_html(post.static_site_html) %></div>
        </div>
        <div class="post-date"><%= l(post.publish_at.to_date, format: :long) %></div>
      <% else %>
        <%# Long post with title %>
        <div>
          <a class="post-title" href="<%= static_site_post_url(post) %>"><%= post.title %></a>
          <% if post.book&.rating.present? %>
            <span class="rating" aria-label="<%= post.book.rating %> out of 5 stars">
              <%= static_site_rating_stars(post.book.rating) %>
            </span>
          <% end %>
        </div>
        <div class="post-long-body">
          <% if post.emoji.present? %>
            <div class="post-emoji"><%= post.emoji %></div>
          <% end %>
          <div class="post-long-content">
            <% if post.thumbnail_image&.file&.attached? %>
              <div class="post-thumbnail">
                <img src="<%= static_site_image_url(post.thumbnail_image, :mobile_x1) %>" alt="" loading="lazy">
              </div>
            <% end %>
            <% if post.content.present? %>
              <div class="post-excerpt"><%= post.content_excerpt %></div>
            <% end %>
          </div>
        </div>
        <div class="post-date"><%= l(post.publish_at.to_date, format: :long) %></div>
        <% if post.tag_list.any? %>
          <div class="post-tags">
            <% post.tag_list.each do |tag| %>
              <span class="badge badge-outline"><%= tag %></span>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </article>
    <hr />
  <% end %>
</div>
