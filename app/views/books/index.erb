<%= turbo_frame_tag(:content) do %>
  <%= render PageHeaderComponent.new(title: Book.model_name.human.pluralize) do %>
    <%= render ButtonComponent.new(label: t('books.new_book'), variant: :primary, icon: "plus", href: new_site_book_path, data: { turbo_frame: :content }) %>
  <% end %>

  <ul class="nav nav-tabs mb-3">
    <% Book.reading_statuses.keys.each do |status| %>
      <li class="nav-item">
        <%= link_to t("books.reading_statuses.#{status}"),
                    site_books_path(current_site, status: status),
                    class: "nav-link #{'active' if params[:status] == status || (params[:status].blank? && status == 'finished')}" %>
      </li>
    <% end %>
  </ul>

  <% if @books.empty? %>
    <%= render EmptyStateComponent.new(
          icon: "book",
          message: t("books.reading_statuses.#{params[:status].presence || 'finished'}"),
          action_label: t('books.new_book'),
          action_href: new_site_book_path) %>
  <% else %>
    <%= render TableComponent.new(headers: [
          "",
          t('activerecord.attributes.book.title'),
          t('activerecord.attributes.book.author'),
          t('activerecord.attributes.book.read_at'),
          ""
        ]) do %>
      <%= render @books %>
    <% end %>
  <% end %>
<% end %>
