<tr id="<%= dom_id(book) %>" is="turbo-frame">
  <td class="text-center align-middle">
    <% if book.cover_image&.file&.attached? %>
      <%= image_tag book.cover_image.file.variant(:mobile_x1_webp), style: 'max-height: 50px;' %>
    <% elsif book.emoji.present? %>
      <span style="font-size: 1.5rem;"><%= book.emoji %></span>
    <% end %>
    <% if book.rating.present? %>
      <br><small class="text-warning"><%= '★' * book.rating %><%= '☆' * (5 - book.rating) %></small>
    <% end %>
  </td>
  <td><%= book.title %></td>
  <td><%= book.author %></td>
  <td><%= book.read_at ? l(book.read_at.to_date) : '-' %></td>
  <td class="text-end">
    <% if book.review? %>
      <%= render ButtonComponent.new(label: t('reviews.edit_review'), variant: :secondary, size: :sm, href: edit_site_book_review_path(book.site, book)) %>
    <% else %>
      <%= render ButtonComponent.new(label: t('reviews.write_review'), variant: :secondary, size: :sm, href: new_site_book_review_path(book.site, book)) %>
    <% end %>
    <%= render ButtonComponent.new(
          label: icon('pencil'),
          variant: :secondary,
          size: :sm,
          href: edit_book_path(book),
          aria: { label: t('edit') }) %>
    <%= render ButtonComponent.new(
          label: icon('trash'),
          variant: :danger,
          size: :sm,
          href: book_path(book),
          aria: { label: t('delete') },
          data: { turbo_method: :delete, turbo_confirm: t('are_you_sure') }) %>
  </td>
</tr>
