<%= turbo_frame_tag(:form) do %>
  <%= form_for([current_site, post], class: "mb-4", data: { controller: 'post_form' }) do |form| %>
    <%= component('form/header_image_picker', form:) %>
    <%= component('form/title_and_slug', form:) %>
    <%= component('form/text_field', form:, attribute: :tags) %>
    <%= component('form/editor', form:, attribute: :content) %>
    <%= component('form/datetime_field', form:, attribute: :publish_at, placeholder: Time.current) %>
    <%= component('form/checkbox', form:, attribute: :draft) %>

    <div class="d-flex gap-2">
      <%= render ButtonComponent.new(label: post.persisted? ? "Update Post" : "Create Post", variant: :primary, type: "submit") %>
      <%= render ButtonComponent.new(label: "Cancel", variant: :ghost, href: site_posts_path, "data-turbo-frame": "_top") %>
    </div>
  <% end %>
<% end %>
