<%= turbo_frame_tag(post) do %>
  <article class="post-card">
    <% if post.title.present? %>
      <div class="post-card-title"><%= post.emoji %> <%= post.title %></div>
      <div class="post-card-body">
        <% if post.thumbnail_image&.file&.attached? %>
          <div class="post-card-thumbnail">
            <%= image_tag post.thumbnail_image.file.variant(:mobile_x1_webp), class: "post-card-thumbnail__img" %>
          </div>
        <% end %>
        <% if post.content.present? %>
          <div class="post-card-excerpt"><%= post.content_excerpt %></div>
        <% end %>
      </div>
    <% else %>
      <div class="post-card-content"><%= post.content_html %></div>
    <% end %>
    <% if post.book.present? %>
      <div class="post-card-book">
        <% if post.book.cover_image&.file&.attached? %>
          <%= image_tag post.book.cover_image.file.variant(:mobile_x1_webp), style: 'max-height: 40px;', class: 'rounded' %>
        <% elsif post.book.emoji.present? %>
          <span class="post-card-book__emoji"><%= post.book.emoji %></span>
        <% end %>
        <div class="post-card-book__info">
          <div class="post-card-book__title"><%= post.book.title %></div>
          <div class="post-card-book__author"><%= post.book.author %></div>
        </div>
        <% if post.book.rating.present? %>
          <small class="post-card-book__rating"><%= '★' * post.book.rating %><%= '☆' * (5 - post.book.rating) %></small>
        <% end %>
      </div>
    <% end %>
    <div class="post-card-meta">
      <%= render BadgeComponent.new(label: l(post.publish_at, format: :long), variant: :neutral) %>
      <% if post.draft? %>
        <%= render BadgeComponent.new(label: "Draft", variant: :accent) %>
      <% end %>
      <% post.tag_list.each do |tag| %>
        <%= render BadgeComponent.new(label: tag, variant: :neutral) %>
      <% end %>
    </div>
    <div class="post-card-actions">
      <%= render ButtonComponent.new(label: "Edit", variant: :secondary, size: :sm, href: edit_site_post_path(current_site, post), data: { turbo_frame: :content }) %>
      <%= render ButtonComponent.new(label: "Delete", variant: :danger, size: :sm, href: site_post_path(current_site, post), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }) %>
    </div>
  </article>
<% end %>
