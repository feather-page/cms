<%= turbo_frame_tag(:content) do %>
  <%= render PageHeaderComponent.new(title: "Blogposts") do %>
    <%= render ButtonComponent.new(label: "New Post", variant: :primary, icon: "plus", href: new_site_post_path) %>
  <% end %>

  <%= turbo_frame_tag(:posts) do %>
    <% if @posts.empty? %>
      <%= render EmptyStateComponent.new(emoji: "✏️", message: "Noch keine Blogposts", subtitle: "Schreibe deinen ersten Post und teile ihn mit der Welt.", action_label: "Neuer Post", action_href: new_site_post_path) %>
    <% else %>
      <% @posts.each do |post| %>
        <%= render PostListItemComponent.new(post: post, site: current_site) %>
      <% end %>
      <%= render('layouts/pagination') %>
    <% end %>
  <% end %>
<% end %>
