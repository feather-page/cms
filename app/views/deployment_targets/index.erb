<%= turbo_frame_tag(:content) do %>
  <%= render PageHeaderComponent.new(title: "Deployment Targets") %>

  <% if @deployment_targets.empty? %>
    <%= render EmptyStateComponent.new(icon: "globe", message: "No deployment targets configured") %>
  <% else %>
    <% @deployment_targets.each do |target| %>
      <%= render DeploymentTargetRowComponent.new(target: target, site: current_site) %>
    <% end %>
  <% end %>
<% end %>
