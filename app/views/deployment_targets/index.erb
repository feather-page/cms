<%= turbo_frame_tag(:content) do %>
  <%= render PageHeaderComponent.new(title: "Deployment Targets") %>

  <% if @deployment_targets.empty? %>
    <%= render EmptyStateComponent.new(icon: "box-seam", message: "No deployment targets configured") %>
  <% else %>
    <%= render TableComponent.new(headers: ["URL", "Type", ""]) do %>
      <%= render @deployment_targets %>
    <% end %>
  <% end %>
<% end %>
