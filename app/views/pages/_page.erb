<tr id="<%= dom_id(page) %>" is="turbo-frame">
  <td>
    <% if page.thumbnail_image&.file&.attached? %>
      <%= image_tag page.thumbnail_image.file.variant(:mobile_x1_webp), style: 'width: 40px; height: 40px; object-fit: cover; border-radius: 4px;' %>
    <% end %>
  </td>
  <td><%= page.title %></td>
  <td><%= page.slug %></td>
  <td>
    <% page.tag_list.each do |tag| %>
      <%= render BadgeComponent.new(label: tag, variant: :neutral) %>
    <% end %>
  </td>
  <td class="text-end">
    <%= render ButtonComponent.new(label: icon("pencil"), variant: :ghost, size: :sm, href: edit_site_page_path(current_site, page), data: { turbo_frame: :content }, title: t('edit'), aria: { label: t('edit') }) %>
    <%= render ButtonComponent.new(label: icon("trash"), variant: :ghost, size: :sm, href: site_page_path(current_site, page), data: { turbo_method: :delete, turbo_confirm: t('are_you_sure') }, title: t('delete'), aria: { label: t('delete') }) %>
    <%= render ButtonComponent.new(label: icon("plus"), variant: :ghost, size: :sm, href: navigation_items_path(site_id: current_site, page_id: page), data: { turbo_method: :post }, title: t('navigation.add_page'), aria: { label: t('navigation.add_page') }) %>
  </td>
</tr>
