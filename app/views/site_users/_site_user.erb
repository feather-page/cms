<tr id="<%= dom_id(site_user) %>" is="turbo-frame">
  <td><%= site_user.user.email %></td>
  <td class="text-end">
    <% if policy(site_user).destroy? %>
      <%= render ButtonComponent.new(label: t('.remove'), variant: :danger, size: :sm, href: site_user_path(site_user.site, site_user), data: { turbo_method: :delete, turbo_confirm: t('are_you_sure') }) %>
    <% end %>
  </td>
</tr>
