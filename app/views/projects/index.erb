<%= turbo_frame_tag(:content) do %>
  <%= render PageHeaderComponent.new(title: Project.model_name.human.pluralize) do %>
    <%= render ButtonComponent.new(label: t('projects.new_project'), variant: :primary, icon: "plus", href: new_site_project_path, data: { turbo_frame: :content }) %>
  <% end %>

  <%= turbo_frame_tag(:projects) do %>
    <% if @projects.empty? %>
      <%= render EmptyStateComponent.new(emoji: "🏗️", message: "Keine Projekte", subtitle: "Zeige deine Arbeit und Projekte.", action_label: t('projects.new_project'), action_href: new_site_project_path) %>
    <% else %>
      <% @projects.each do |project| %>
        <%= render ProjectListItemComponent.new(project: project, site: current_site) %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
